# Convex deployment URL (from: npx convex dev)
VITE_CONVEX_URL=https://your-project.convex.cloud

# Tribe center coordinates (replace with your event location)
VITE_TRIBE_LAT=51.5074
VITE_TRIBE_LNG=-0.1278

# Google AdSense publisher ID (replace with yours, format: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# AdSense ad-unit slot IDs (numeric strings from each created ad unit).
# Leave blank to render the dev placeholder for that slot.
VITE_ADSENSE_SLOT_CHAT=
VITE_ADSENSE_SLOT_LANDING=
VITE_ADSENSE_SLOT_MANIFESTO=
VITE_ADSENSE_SLOT_STATS=
